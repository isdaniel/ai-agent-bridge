# Copy this file to .env and fill in the values you need.

# ── LINE (--platform line) ──────────────────────────────────────────────
LINE_CHANNEL_SECRET=
LINE_CHANNEL_TOKEN=

# ── Slack (--platform slack) ────────────────────────────────────────────
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# ── Logging ─────────────────────────────────────────────────────────────
# tracing-style filter; comment out for default (info).
# AAB_LOG=info,platform_line=debug,agent_claude_code=debug

# ── ngrok (fixed webhook URL for LINE) ─────────────────────────────────
# Free tier: https://ngrok.com → sign up → Dashboard → Domains → Create Domain
# First run: ngrok config add-authtoken <YOUR_TOKEN>
# If unset, falls back to cloudflared quick tunnels (random URL each restart).
NGROK_DOMAIN=
AAB_AGENTS__CLAUDE__MODEL=
#AAB_AGENTS__CLAUDE__CLIENT_CONFIG_BASE_DIR=
#AAB_AGENTS__CLAUDE__CLIENT_TEMPLATE_DIR=