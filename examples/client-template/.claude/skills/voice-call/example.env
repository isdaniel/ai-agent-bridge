# Azure Communication Services - Voice Call Configuration
# Copy this file to .env and fill in your values:
#   cp example.env .env

ACS_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=YOUR_ACCESS_KEY
ACS_PHONE_NUMBER=+1XXXXXXXXXX
COGNITIVE_SERVICES_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
CALLBACK_PORT=9090
